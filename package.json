{
  "name": "new-challenge-tracker",
  "version": "1.0.3",
  "description": "",
  "license": "ISC",
  "author": "",
  "main": "app/main.js",
  "scripts": {
    "start": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build:win": "electron-builder --win",
    "publish:win": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^42.5.0",
    "electron-builder": "^24.6.4"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "ws": "^8.17.0"
  },
  "build": {
    "appId": "com.challengetracker.app",
    "productName": "Challenge Tracker",
    "publish": [
      {
        "provider": "github",
        "owner": "Mynute",
        "repo": "LoL-Tracker"
      }
    ],
    "directories": {
      "buildResources": "static/assets"
    },
    "files": [
      "app/**/*",
      "static/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "static/assets/tracker.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
